# ============================================================
# MiniCloud Platform — Required Environment Variables
# Copy this file to .env and fill in real values before
# running: docker compose --env-file .env up -d
# ============================================================

# ----------------------------------------------------------
# SECURITY (REQUIRED)
# Generate a strong 64-character random hex key, e.g.:
#   openssl rand -hex 32
# ----------------------------------------------------------
JWT_SECRET=

# ----------------------------------------------------------
# EMAIL / NOTIFICATIONS  (required by minicloud-notification)
# Use a Gmail App Password, not your real account password.
# ----------------------------------------------------------
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-google-app-password

# ----------------------------------------------------------
# DATABASE — override the defaults if using an external DB
# (the defaults work for the bundled postgres-db container)
# ----------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres-db:5432/minicloud
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# ----------------------------------------------------------
# MINIO — override if using an external MinIO or S3 endpoint
# ----------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000

# ----------------------------------------------------------
# Optional: Twilio / SMS notifications
# ----------------------------------------------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
