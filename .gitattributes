# Automatically normalize line endings to LF on commit
* text=auto eol=lf

# Java and XML source files — always LF
*.java text eol=lf
*.xml  text eol=lf
*.properties text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.css  text eol=lf

# Maven wrapper — binary
mvnw   text eol=lf
mvnw.cmd text eol=crlf

# Binary files — no line ending conversion
*.jar  binary
*.class binary
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.zip  binary
*.war  binary
*.ear  binary
