<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.console.controller.VpcController" spacing="15" styleClass="view-container">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="VPC Networks" styleClass="header-label"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Create VPC" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="VPC ID" prefWidth="150"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="200"/>
            <TableColumn fx:id="cidrColumn" text="CIDR Block" prefWidth="150"/>
            <TableColumn fx:id="stateColumn" text="State" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
