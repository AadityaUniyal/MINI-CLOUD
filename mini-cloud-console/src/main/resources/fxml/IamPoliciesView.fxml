<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.console.controller.IamPoliciesController" spacing="15" styleClass="view-container">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="IAM Policies" styleClass="header-label"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Create Policy" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Policy Name" prefWidth="200"/>
            <TableColumn fx:id="arnColumn" text="Policy ARN" prefWidth="350"/>
            <TableColumn fx:id="descColumn" text="Description" prefWidth="250"/>
        </columns>
    </TableView>
</VBox>
