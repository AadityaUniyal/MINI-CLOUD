<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" alignment="CENTER" spacing="30" style="-fx-background-color: transparent;">
    <padding>
        <Insets top="50" bottom="50" left="50" right="50"/>
    </padding>
    
    <VBox alignment="CENTER" spacing="10">
        <Label text="Welcome to MiniCloud" styleClass="header-label" style="-fx-font-size: 48px;"/>
        <Label text="Your AWS-Style Management Console" style="-fx-text-fill: #94a3b8; -fx-font-size: 18px;"/>
    </VBox>

    <HBox alignment="CENTER" spacing="20">
        <VBox style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 30; -fx-background-radius: 15; -fx-pref-width: 200;" alignment="CENTER" spacing="15">
            <Label text="EC2" style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #3b82f6;"/>
            <Label text="Virtual Servers" style="-fx-text-fill: #64748b;"/>
        </VBox>
        <VBox style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 30; -fx-background-radius: 15; -fx-pref-width: 200;" alignment="CENTER" spacing="15">
            <Label text="S3" style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #10b981;"/>
            <Label text="Object Storage" style="-fx-text-fill: #64748b;"/>
        </VBox>
        <VBox style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 30; -fx-background-radius: 15; -fx-pref-width: 200;" alignment="CENTER" spacing="15">
            <Label text="IAM" style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #f59e0b;"/>
            <Label text="Access Mgmt" style="-fx-text-fill: #64748b;"/>
        </VBox>
    </HBox>

    <VBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">
        <Label text="Get started by selecting a service from the sidebar." style="-fx-text-fill: #94a3b8; -fx-font-style: italic;"/>
    </VBox>
</VBox>
