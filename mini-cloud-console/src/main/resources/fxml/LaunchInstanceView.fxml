<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.console.controller.LaunchInstanceController" spacing="15" styleClass="view-container" style="-fx-background-color: #1e293b;">
    <padding>
        <Insets top="30" bottom="30" left="30" right="30"/>
    </padding>

    <Label text="Launch New Instance" styleClass="header-label"/>
    
    <VBox spacing="5">
        <Label text="Instance Name" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="nameField" promptText="e.g. my-web-app" style="-fx-background-color: #0f172a; -fx-text-fill: white;"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Amazon Machine Image (AMI)" style="-fx-text-fill: #94a3b8;"/>
        <ComboBox fx:id="amiCombo" maxWidth="Infinity" style="-fx-background-color: #0f172a;"/>
    </VBox>

    <VBox spacing="5">
        <Label text="VPC Network" style="-fx-text-fill: #94a3b8;"/>
        <ComboBox fx:id="vpcCombo" maxWidth="Infinity" style="-fx-background-color: #0f172a;"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" styleClass="nav-button"/>
        <Button text="Launch" onAction="#handleLaunch" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;"/>
    </HBox>
</VBox>
