<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.admin.controller.CloudTrailController" spacing="15" styleClass="view-container">
    <padding>
        <Insets top="20" bottom="20" left="20" right="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="CloudTrail Event History" styleClass="header-label"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <TextField promptText="Filter events..." prefWidth="250" style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white;"/>
        <Button text="Download Events (CSV)" styleClass="nav-button"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="timeColumn" text="Event Time" prefWidth="150"/>
            <TableColumn fx:id="nameColumn" text="Event Name" prefWidth="180"/>
            <TableColumn fx:id="userColumn" text="User" prefWidth="120"/>
            <TableColumn fx:id="resourceColumn" text="Resource ID" prefWidth="120"/>
            <TableColumn fx:id="ipColumn" text="Source IP" prefWidth="120"/>
            <TableColumn fx:id="detailsColumn" text="Details" prefWidth="300"/>
        </columns>
    </TableView>
</VBox>
