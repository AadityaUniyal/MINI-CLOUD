<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.minicloud.admin.controller.MainController" stylesheets="@../css/index.css">
    <left>
        <VBox spacing="10" styleClass="sidebar" prefWidth="250">
            <padding>
                <Insets top="30" right="15" bottom="30" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="MINICLOUD" styleClass="logo-text"/>
                <Label text="PRO" styleClass="badge-premium"/>
            </HBox>
            <Separator style="-fx-opacity: 0.1;"/>
            
            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <Button text="Dashboard" onAction="#onDashboardClick" maxWidth="Infinity" styleClass="nav-btn, active-nav">
                    <graphic><org.kordamp.ikonli.javafx.FontIcon iconLiteral="mdz-view-dashboard" iconSize="18"/></graphic>
                </Button>
                <Button text="EC2 Instances" onAction="#onInstancesClick" maxWidth="Infinity" styleClass="nav-btn">
                    <graphic><org.kordamp.ikonli.javafx.FontIcon iconLiteral="mdz-server" iconSize="18"/></graphic>
                </Button>
                <Button text="S3 Storage" onAction="#onStorageClick" maxWidth="Infinity" styleClass="nav-btn">
                    <graphic><org.kordamp.ikonli.javafx.FontIcon iconLiteral="mdz-folder" iconSize="18"/></graphic>
                </Button>
                <Button text="RDS Databases" onAction="#onDatabasesClick" maxWidth="Infinity" styleClass="nav-btn">
                    <graphic><org.kordamp.ikonli.javafx.FontIcon iconLiteral="mdz-database" iconSize="18"/></graphic>
                </Button>
                <Button text="IAM Management" onAction="#onIamClick" maxWidth="Infinity" styleClass="nav-btn">
                    <graphic><org.kordamp.ikonli.javafx.FontIcon iconLiteral="mdz-shield-account" iconSize="18"/></graphic>
                </Button>
            </VBox>
            
            <Separator style="-fx-opacity: 0.1;"/>
            <Button text="Sign Out" onAction="#onLogoutClick" maxWidth="Infinity" styleClass="nav-btn, logout-btn">
                <graphic><org.kordamp.ikonli.javafx.FontIcon iconLiteral="mdz-logout" iconSize="18"/></graphic>
            </Button>
        </VBox>
    </left>
    
    <center>
        <VBox>
            <HBox spacing="20" alignment="CENTER_LEFT" styleClass="top-bar">
                <padding><Insets left="30" right="30"/></padding>
                <TextField fx:id="searchField" placeholder="Search resources, docs..." prefWidth="350" styleClass="search-field"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ChoiceBox fx:id="regionSwitcher" prefWidth="150" styleClass="region-switcher"/>
                <Button styleClass="icon-btn">
                    <graphic><org.kordamp.ikonli.javafx.FontIcon iconLiteral="mdz-bell-outline" iconSize="20"/></graphic>
                </Button>
                <Button styleClass="profile-btn">
                    <graphic><org.kordamp.ikonli.javafx.FontIcon iconLiteral="mdz-account-circle" iconSize="28"/></graphic>
                </Button>
            </HBox>
            
            <StackPane fx:id="contentPane" VBox.vgrow="ALWAYS" styleClass="main-content-stack">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <!-- Dynamic views loaded here -->
            </StackPane>
        </VBox>
    </center>
</BorderPane>
