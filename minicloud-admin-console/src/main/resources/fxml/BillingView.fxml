<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.admin.controller.BillingController" spacing="20" styleClass="view-container">
    <padding>
        <Insets top="20" bottom="20" left="20" right="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Billing &amp; Cost Explorer" styleClass="header-label"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Update Simulation" onAction="#handleRefresh" styleClass="nav-button"/>
    </HBox>

    <HBox spacing="20">
        <VBox styleClass="metric-card" prefWidth="250">
            <Label text="Estimated Monthly Cost" styleClass="metric-label"/>
            <Label fx:id="totalCostLabel" text="\$0.00" styleClass="metric-value" style="-fx-text-fill: #10b981;"/>
            <Label text="Next bill: May 1st, 2024" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
        </VBox>
        
        <VBox prefWidth="400" spacing="10" style="-fx-background-color: rgba(255,255,255,0.02); -fx-padding: 15; -fx-background-radius: 8;" HBox.hgrow="ALWAYS" prefHeight="250">
            <Label text="Monthly Spending Trend" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold;"/>
            <BarChart fx:id="costChart" legendVisible="false" animated="false">
                <xAxis><CategoryAxis side="BOTTOM"/></xAxis>
                <yAxis><NumberAxis side="LEFT" label="USD"/></yAxis>
            </BarChart>
        </VBox>
    </HBox>

    <VBox spacing="10">
        <Label text="Payment Method" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold;"/>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: rgba(255,255,255,0.02); -fx-padding: 10; -fx-background-radius: 8;">
            <Label text="💳" style="-fx-font-size: 20px;"/>
            <Label text="Visa ending in 4242" style="-fx-text-fill: white;"/>
            <Button text="Manage" style="-fx-text-fill: #3b82f6; -fx-background-color: transparent;"/>
        </HBox>
    </VBox>
</VBox>
