<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" alignment="CENTER" spacing="20" style="-fx-background-color: transparent;">
    <padding>
        <Insets top="50" bottom="50" left="50" right="50"/>
    </padding>

    <Label text="🔍" style="-fx-font-size: 64px; -fx-opacity: 0.2;"/>
    
    <VBox alignment="CENTER" spacing="5">
        <Label fx:id="titleLabel" text="No Resources Found" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label fx:id="descriptionLabel" text="You don't have any active resources in this region." style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
    </VBox>

    <Button text="Create Resource" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;"/>
</VBox>
