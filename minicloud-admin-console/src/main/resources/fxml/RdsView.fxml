<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.admin.controller.RdsController" spacing="15" styleClass="view-container">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="RDS Databases" styleClass="header-label"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Create Database" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="10" style="-fx-background-color: rgba(255,255,255,0.02); -fx-padding: 10; -fx-background-radius: 8;">
        <Button fx:id="stopButton" text="Stop DB" onAction="#handleStop" disable="true" styleClass="nav-button" style="-fx-padding: 5 15;"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
            <TableColumn fx:id="nameColumn" text="DB Name" prefWidth="250"/>
            <TableColumn fx:id="engineColumn" text="Engine" prefWidth="150"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>
