<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.admin.controller.S3Controller" spacing="15" styleClass="view-container">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="S3 Buckets" styleClass="header-label"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Create Bucket" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="10" style="-fx-background-color: rgba(255,255,255,0.02); -fx-padding: 10; -fx-background-radius: 8;">
        <Button fx:id="viewObjectsButton" text="View Objects" onAction="#handleViewObjects" disable="true" styleClass="nav-button"/>
        <Button fx:id="deleteBucketButton" text="Delete Bucket" onAction="#handleDeleteBucket" disable="true" styleClass="nav-button" style="-fx-text-fill: #ef4444;"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
            <TableColumn fx:id="nameColumn" text="Bucket Name" prefWidth="300"/>
            <TableColumn fx:id="regionColumn" text="Region" prefWidth="200"/>
        </columns>
    </TableView>
</VBox>
