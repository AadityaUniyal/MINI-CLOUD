<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.admin.controller.InvokeLambdaController" spacing="15" styleClass="view-container" style="-fx-background-color: #1e293b;">
    <padding>
        <Insets top="30" bottom="30" left="30" right="30"/>
    </padding>

    <Label fx:id="titleLabel" text="Invoke Lambda Selection" styleClass="header-label"/>
    
    <VBox spacing="5" VBox.vgrow="ALWAYS">
        <Label text="JSON Payload" style="-fx-text-fill: #94a3b8;"/>
        <TextArea fx:id="payloadArea" promptText='{ "key": "value" }' prefHeight="100" style="-fx-control-inner-background: #0f172a; -fx-text-fill: #10b981; -fx-font-family: "Consolas";"/>
    </VBox>

    <VBox spacing="5" VBox.vgrow="ALWAYS">
        <Label text="Execution Result" style="-fx-text-fill: #94a3b8;"/>
        <TextArea fx:id="resultArea" editable="false" prefHeight="150" style="-fx-control-inner-background: #0f172a; -fx-text-fill: #3b82f6; -fx-font-family: "Consolas";"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Close" onAction="#handleClose" styleClass="nav-button"/>
        <Button text="Execute" onAction="#handleInvoke" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;"/>
    </HBox>
</VBox>
