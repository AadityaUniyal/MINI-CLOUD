<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.admin.controller.DashboardController" spacing="30" styleClass="view-container">
    <Label text="Cloud Dashboard" styleClass="header-label"/>
    
    <FlowPane hgap="20" vgap="20">
        <VBox styleClass="metric-card">
            <Label text="Instances" styleClass="metric-label"/>
            <Label fx:id="instanceCountLabel" text="0" styleClass="metric-value"/>
        </VBox>
        
        <VBox styleClass="metric-card">
            <Label text="S3 Buckets" styleClass="metric-label"/>
            <Label fx:id="bucketCountLabel" text="0" styleClass="metric-value" style="-fx-text-fill: #10b981;"/>
        </VBox>
        
        <VBox styleClass="metric-card">
            <Label text="IAM Users" styleClass="metric-label"/>
            <Label fx:id="userCountLabel" text="0" styleClass="metric-value" style="-fx-text-fill: #f59e0b;"/>
        </VBox>
        
        <VBox styleClass="metric-card">
            <Label text="Functions" styleClass="metric-label"/>
            <Label fx:id="lambdaCountLabel" text="0" styleClass="metric-value" style="-fx-text-fill: #8b5cf6;"/>
        </VBox>
    </FlowPane>
    
    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <Label text="System Status" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;"/>
        <HBox spacing="20">
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="API Status:" style="-fx-text-fill: #94a3b8;"/>
                    <Label fx:id="apiStatusLabel" text="ONLINE" styleClass="status-pill, status-running"/>
                </HBox>
                <Label text="Region: us-east-1 (N. Virginia)" style="-fx-text-fill: #64748b;"/>
            </VBox>
            
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(255,255,255,0.02); -fx-padding: 15; -fx-background-radius: 8;">
                <Label text="RECENT ACTIVITY (Audit Logs)" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <javafx.scene.control.TableView fx:id="activityTable" prefHeight="150" style="-fx-background-color: transparent;">
                    <columns>
                        <javafx.scene.control.TableColumn fx:id="timeColumn" text="Time" prefWidth="120"/>
                        <javafx.scene.control.TableColumn fx:id="actionColumn" text="Action" prefWidth="150"/>
                        <javafx.scene.control.TableColumn fx:id="resourceColumn" text="Resource" prefWidth="130"/>
                    </columns>
                </javafx.scene.control.TableView>
            </VBox>
        </HBox>
    </VBox>
</VBox>
