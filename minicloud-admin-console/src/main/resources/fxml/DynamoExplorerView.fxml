<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minicloud.admin.controller.DynamoExplorerController" spacing="15" styleClass="view-container">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="← Back" onAction="#handleBack" styleClass="nav-button"/>
        <Label fx:id="tableNameLabel" text="Table Explorer" styleClass="header-label"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Put Item" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="keyColumn" text="Partition Key" prefWidth="200"/>
            <TableColumn fx:id="valueColumn" text="Attributes (JSON)" prefWidth="500"/>
        </columns>
    </TableView>
</VBox>
